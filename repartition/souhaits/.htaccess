# Interdit l'accès HTTP direct aux fichiers de souhaits (<login>.json).
# Ils ne sont lus/écrits que par get.php / save.php (contrôle de session),
# jamais servis en statique. Les scripts PHP restent accessibles.
<FilesMatch "\.json$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
